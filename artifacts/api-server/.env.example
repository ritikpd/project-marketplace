# Node Environment
NODE_ENV=production

# Allowed Origins (comma-separated, no spaces)
ALLOWED_ORIGINS=https://nepzia.example.com,https://app.nepzia.example.com

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nepzia

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_STORAGE_BUCKET=nepzia-uploads
GOOGLE_CLOUD_KEYFILE=/path/to/keyfile.json

# Server
PORT=3000
HOST=0.0.0.0

# Logging
LOG_LEVEL=info